# Pipeline
INPUT_CSV=samples/sellers.csv
OUTPUT_CSV=samples/enriched.csv
CONCURRENCY=2
MIN_CONFIDENCE=0.70

# Provider selection: mock | registry-api
PROVIDER=mock

# Generic registry API adapter. Replace with an approved vendor endpoint only.
REGISTRY_API_BASE_URL=https://example-registry-provider.invalid/search
REGISTRY_API_KEY=replace_me
REGISTRY_AUTH_MODE=bearer

# Google Sheets optional adapter
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
GOOGLE_SHEET_ID=replace_me
GOOGLE_SHEET_NAME=Sellers
