{
  "name": "amazon-seller-contact-enrichment",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Compliance-first seller contact enrichment pipeline for SmartScout exports and n8n workflows.",
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "sample": "tsx src/cli.ts --input samples/sellers.csv --output samples/enriched.csv --provider mock"
  },
  "dependencies": {
    "@fast-csv/format": "^5.0.2",
    "@fast-csv/parse": "^5.0.2",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "googleapis": "^144.0.0",
    "p-limit": "^6.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
